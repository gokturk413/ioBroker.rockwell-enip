<Description>
<![CDATA[OpenConnection MSG source (the AOI fills Timeout + DestAddr). Set as Msg_Connect Source Element.]]>
<LocalizedDescription Lang="en-US">
<![CDATA[OpenConnection MSG source (the AOI fills Timeout + DestAddr). Set as Msg_Connect Source Element.]]>
</LocalizedDescription>
</Description>
</Parameter>
<Parameter Name="WriteP" TagType="Base" DataType="IOB_SockWrite" Usage="InOut" Required="true" Visible="true" Constant="false">

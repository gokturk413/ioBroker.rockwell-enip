<AddOnInstructionDefinitions Use="Context">
<EncodedData EncodedType="AddOnInstructionDefinition" Name="IOB_PushAgent" Revision="1.0" Vendor="ioBroker" SignatureID="D8A87D60" SignatureTimestamp="2026-07-16T09:40:53.623Z" EditedDate="2026-07-16T09:40:53.623Z" SoftwareRevision="v38.00" EncryptionConfig="9">
<Description>
<![CDATA[Change-driven push to ioBroker over a Logix Socket Object (ENET-AT002). IOB_PushMap copies tags into Buf.*Shadow; this AOI opens a TCP socket to DestAddr, diffs shadow vs last each scan and WriteSockets a frame of changed (index,kind,raw). Socket param tags are InOut so the 3 MSGs (Socket Create 4b / OpenConnection 4c / WriteSocket 4e, class 342, UNCONNECTED) reference the same controller tags the AOI fills. Source-protect with your own key before deploying.]]>
</Description>
<Parameters>
<Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Input - System Defined Parameter]]>
<LocalizedDescription Lang="en-US">
<![CDATA[Enable Input - System Defined Parameter]]>
</LocalizedDescription>
</Description>
</Parameter>
<Parameter Name="EnableOut" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Output - System Defined Parameter]]>
<LocalizedDescription Lang="en-US">
<![CDATA[Enable Output - System Defined Parameter]]>
</LocalizedDescription>
</Description>
</Parameter>

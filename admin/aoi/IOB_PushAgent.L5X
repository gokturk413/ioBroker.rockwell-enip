<![CDATA[Shadow buffers (IOB_Push_Buf).]]>
<LocalizedDescription Lang="en-US">
<![CDATA[Shadow buffers (IOB_Push_Buf).]]>
</LocalizedDescription>
</Description>
</Parameter>
<Parameter Name="DestAddr" TagType="Base" DataType="STRING" Usage="InOut" Required="true" Visible="true" Constant="false">
<Description>
<![CDATA[ioBroker engine as "hostIP?port=NNNN", e.g. 192.168.0.5?port=44819.]]>
<LocalizedDescription Lang="en-US">
<![CDATA[ioBroker engine as "hostIP?port=NNNN", e.g. 192.168.0.5?port=44819.]]>
</LocalizedDescription>
</Description>
</Parameter>
<Parameter Name="Connected" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="true" ExternalAccess="Read Only">
<Description>
<![CDATA[TRUE while the push socket is up.]]>
<LocalizedDescription Lang="en-US">
<![CDATA[TRUE while the push socket is up.]]>
</LocalizedDescription>
</Description>
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="CreateP" TagType="Base" DataType="IOB_SockCreate" Usage="InOut" Required="true" Visible="true" Constant="false">
<Description>
<![CDATA[Socket Create MSG source (the AOI fills it). Set as Msg_Create Source Element.]]>
<LocalizedDescription Lang="en-US">
